data/custom_scenarios.jsonl
data/uploaded_scenarios.jsonl
data/selected_scenarios.jsonl

# Generated run results, analytics, and reports (recreate by running an experiment, or via
# scripts/parse_results.py, scripts/build_analytics_db.py, scripts/make_report.py)
results/runs/**/*.jsonl
!results/runs/.gitkeep
results/summary.csv
results/leaderboard.csv
results/analytics.duckdb
reports/final_report.md
reports/figures/*
!reports/figures/.gitkeep
